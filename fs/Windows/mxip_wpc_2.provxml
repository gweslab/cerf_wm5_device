            <!-- Microsoft Mobile Device PCA -->
            <characteristic type="90954D07A0E0CF5206D0729A482D8D9C411459A8"> 
                <parm name="EncodedCertificate" value="" />
            </characteristic>
        </characteristic>

        <characteristic type="Privileged Execution Trust Authorities"> 
            <!-- Microsoft Mobile Device Privileged Component PCA -->
            <characteristic type="1C9D6E42F467BB135BB1DDBf2624F7ECC3C92DAB"> 
                <parm name="EncodedCertificate" value=""/>
            </characteristic>
            <!-- Microsoft Windows CE Cryptographic Service Provider Signature CA -->
	   <characteristic type="C93ACDAAB9D0647ADD6B150B63880687F170CF8F">
	       <parm name="EncodedCertificate" value="" /> 
	   </characteristic>
        </characteristic>

        <characteristic type="SPC">
